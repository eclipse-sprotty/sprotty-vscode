{
    "compilerOptions": {
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "downlevelIteration": true,
        "ignoreDeprecations": "6.0",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "ES2017",
        "lib": [
            "ES2017"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noUnusedLocals": true,
        "noImplicitOverride": true,
        "skipLibCheck": true,
        "strict": true,
        "strictPropertyInitialization": false
    }
}
